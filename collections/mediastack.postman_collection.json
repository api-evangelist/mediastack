        {
          "id": "7e09eb9a-de3a-419e-bb3b-13b99ba2e4d4",
          "name": "Search Live News Articles",
          "request": {
            "name": "Search Live News Articles",
            "description": {
              "content": "Retrieve live, real-time news articles aggregated from thousands of publishers worldwide.\nFilter by source, category, country, language, keywords, and date. Supports pagination\nthrough limit/offset. The `date` parameter enables historical lookups on paid plans.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "news"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "access_key",
                  "value": "<string>",
                  "description": "(Required) Mediastack API access key."
                },
                {
                  "disabled": false,
                  "key": "sources",
                  "value": "<string>",
                  "description": "Comma-separated list of source identifiers to include or exclude (prefix with `-` to exclude)."
                },
                {
                  "disabled": false,
                  "key": "categories",
                  "value": "<string>",
                  "description": "Comma-separated list of categories to include or exclude (prefix with `-` to exclude)."
                },
                {
                  "disabled": false,
                  "key": "countries",
                  "value": "<string>",
                  "description": "Comma-separated list of ISO 3166-1 alpha-2 country codes to include or exclude."
                },
                {
                  "disabled": false,
                  "key": "languages",
                  "value": "<string>",
                  "description": "Comma-separated list of ISO 639-1 language codes to include or exclude."
                },
                {
                  "disabled": false,
                  "key": "keywords",
                  "value": "<string>",
                  "description": "Free-text keywords to search across article title, description, and body."
                },
                {
                  "disabled": false,
                  "key": "date",
                  "value": "<string>",
                  "description": "Filter by publication date or date range (paid plans only).\nSingle date `YYYY-MM-DD` or range `YYYY-MM-DD,YYYY-MM-DD`.\n"
                },
                {
                  "disabled": false,
                  "key": "sort",
                  "value": "published_desc",
                  "description": "Sort order for results."
                },
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "25",
                  "description": "Number of results per page (max 100)."
                },
                {
                  "disabled": false,
                  "key": "offset",
                  "value": "0",
                  "description": "Pagination offset."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
